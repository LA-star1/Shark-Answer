# =============================================================================
# Shark Answer - A-Level CIE Exam Answer Generation System
# =============================================================================
# Copy this file to .env and fill in your API keys

# --- Primary Models ---
ANTHROPIC_API_KEY=sk-ant-...        # Claude (Pipeline A/B/C primary)
OPENAI_API_KEY=sk-...               # GPT-4o (Pipeline A/B/C primary)
DEEPSEEK_API_KEY=sk-...             # DeepSeek (Pipeline A/C primary, B supplementary)

# --- Supplementary Models (Pipeline B essay brainstorming) ---
GOOGLE_GEMINI_API_KEY=...           # Gemini
QWEN_API_KEY=sk-...                 # Qwen (via DashScope or compatible endpoint)

# --- Optional Models (not used by default, can swap in via config) ---
GROK_API_KEY=xai-...                # Grok
MINIMAX_API_KEY=...                 # MiniMax
KIMI_API_KEY=...                    # Kimi (Moonshot)

# --- Qwen endpoint (DashScope compatible) ---
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# --- DeepSeek endpoint ---
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- Kimi endpoint ---
KIMI_BASE_URL=https://api.moonshot.cn/v1

# --- MiniMax endpoint ---
MINIMAX_BASE_URL=https://api.minimax.chat/v1

# --- Grok endpoint ---
GROK_BASE_URL=https://api.x.ai/v1

# --- Application Settings ---
LOG_LEVEL=INFO
MAX_CONCURRENT_MODELS=5             # Max parallel model calls
COST_BUDGET_WARNING_USD=5.00        # Warn when single paper exceeds this cost
DEFAULT_LANGUAGE=en                 # en or zh (bilingual output)
UPLOAD_DIR=data/uploads
